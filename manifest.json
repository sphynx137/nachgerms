{
  "name": "NachGerms — UI Panel",
  "version": "1.2.9",
  "description": "Color de interfaz (bordes + texto) y fondo personalizables para Germs.io. Compatible con Germsfox.",
  "manifest_version": 3,

  "icons": {
    "16":  "images/icons/icon-16.png",
    "48":  "images/icons/icon-48.png",
    "128": "images/icons/icon-128.png"
  },

  "action": {
    "default_popup": "src/welcome.html",
    "default_title": "NachGerms UI Panel",
    "default_icon": {
      "16":  "images/icons/icon-16.png",
      "48":  "images/icons/icon-48.png",
      "128": "images/icons/icon-128.png"
    }
  },

  "background": {
    "service_worker": "src/background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://*.germs.io/*"],
      "js": [
        "src/storage.js",
        "src/dom.js",
        "src/content.js"
      ],
      "run_at": "document_end"
    }
  ],

  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://*.germs.io/*"],

  "web_accessible_resources": [
    {
      "resources": ["images/icons/icon-48.png", "src/welcome.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
